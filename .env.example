# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin@123
POSTGRES_DB=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5243
POSTGRES_CONNECTION_STRING=Host=127.0.0.1;Port=5243;Database=postgres;Username=admin;Password=admin@123

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=admin@123
REDIS_CONNECTION_STRING=127.0.0.1:6379,password=admin@123

# Kafka
KAFKA_HOST=127.0.0.1
KAFKA_PORT=9092
KAFKA_BOOTSTRAP_SERVERS=127.0.0.1:9092

# API
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Development

# LLM Providers
OPENAI_API_KEY=sk-your-api-key-here
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# JWT
JWT_ISSUER=QiaKon
JWT_AUDIENCE=QiaKonApi
JWT_KEY=your-super-secret-jwt-key-change-in-production
